{
  "name": "tierlist-global",
  "version": "1.0.0",
  "private": true,
  "description": "TierList Global — Ecosistema de Consenso Auditado",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace @tierlist/api dev\" \"yarn workspace @tierlist/web dev\"",
    "build": "yarn workspace @tierlist/api build && yarn workspace @tierlist/web build",
    "test": "yarn workspace @tierlist/api test && yarn workspace @tierlist/web test",
    "test:e2e": "yarn workspace @tierlist/api test:e2e",
    "lint": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "db:migrate": "yarn workspace @tierlist/api db:migrate",
    "db:seed": "yarn workspace @tierlist/api db:seed",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
