{
  "name": "@tierlist/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config jest.e2e.config.js",
    "db:migrate": "typeorm migration:run -d src/config/datasource.ts",
    "db:seed": "ts-node src/database/seeds/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.spec.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
