## TierList Global — Variables de entorno

# ── Backend (apps/api) ────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=tierlist
DB_PASSWORD=tierlist_secret
DB_NAME=tierlist_global

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARS

# HMAC Secrets (generar con: openssl rand -hex 32)
SVP_HMAC_SECRET=CHANGE_ME_IN_PRODUCTION_SVP_SECRET
AUDIT_HMAC_SECRET=CHANGE_ME_IN_PRODUCTION_AUDIT_SECRET
VOTE_HMAC_SECRET=CHANGE_ME_IN_PRODUCTION_VOTE_SECRET

# SVP Integration
SVP_ENDPOINT_URL=http://localhost:5000/v1/events

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ── Frontend (apps/web-client) ────────────────────────────────
VITE_API_URL=http://localhost:4000
